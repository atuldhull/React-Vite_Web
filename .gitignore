node_modules/

# Local environment files — match every variant (.env, .env.local,
# .env.production, .env.development, .env.test, etc.) so a future
# deploy-specific file can't leak by accident. Only .env.example is
# tracked, by explicit allow.
.env*
!.env.example

*.log
.DS_Store
dist/
coverage/

# Vite production build output — generated by `npm run build`.
# Sources live in frontend/src (code) + frontend/public (static
# assets); this directory is what gets emitted. Render + CI build
# it automatically on every deploy, so there's no value committing
# the artifact. Shipping it used to risk stale bundles sneaking
# into prod if someone forgot to rebuild before a push.
public/app/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Project notes / runbooks / API spec — kept locally only,
# not for public consumption.
docs/

# Internal development notes. Rule: any root-level .md file is
# gitignored UNLESS it's README.md. This protects against future
# "quick doc I wrote about the architecture" files accidentally
# ending up on GitHub. Same policy as the docs/ folder.
/*.md
!/README.md
