{
  "name": "math-club-website",
  "version": "2.0.0",
  "description": "Math Collective — A competitive mathematics platform for university students",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:server": "nodemon backend/server.js",
    "dev:frontend": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "build:frontend": "vite build --config vite.config.js",
    "preview:frontend": "vite preview --config vite.config.js",
    "lint": "eslint frontend/src/ backend/ --ext .js,.jsx --quiet",
    "lint:fix": "eslint frontend/src/ backend/ --ext .js,.jsx --fix",
    "format": "prettier --write \"frontend/src/**/*.{js,jsx,css}\" \"backend/**/*.js\"",
    "format:check": "prettier --check \"frontend/src/**/*.{js,jsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "gen:api-types": "openapi-typescript docs/openapi.yaml -o frontend/src/lib/api-types.d.ts",
    "prepare": "husky"
  },
  "keywords": [
    "math",
    "competitive",
    "university"
  ],
  "author": "Math Collective, BMSIT",
  "license": "MIT",
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/space-grotesk": "5.2.10",
    "@gsap/react": "2.1.2",
    "@noble/curves": "2.2.0",
    "@react-spring/three": "10.0.3",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.5.0",
    "@react-three/postprocessing": "3.0.4",
    "@react-three/rapier": "2.2.0",
    "@sentry/node": "10.48.0",
    "@supabase/supabase-js": "2.103.3",
    "alea": "1.0.1",
    "archiver": "7.0.1",
    "axios": "1.13.6",
    "bcryptjs": "3.0.3",
    "body-parser": "2.2.2",
    "connect-pg-simple": "10.0.0",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "csrf-csrf": "4.0.3",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "express-session": "1.19.0",
    "framer-motion": "12.38.0",
    "gsap": "3.14.2",
    "helmet": "8.1.0",
    "howler": "2.2.4",
    "html5-qrcode": "2.3.8",
    "jsonwebtoken": "9.0.3",
    "lenis": "1.3.21",
    "leva": "0.10.1",
    "mathjs": "15.1.1",
    "multer": "^1.4.5-lts.1",
    "nerdamer": "1.1.13",
    "node-fetch": "3.3.2",
    "nodemailer": "^6.9.13",
    "nodemon": "3.1.14",
    "pdfkit": "^0.15.0",
    "pino": "9.14.0",
    "postprocessing": "6.39.0",
    "qrcode": "1.5.4",
    "qrcode.react": "4.2.0",
    "razorpay": "2.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "react-spring": "10.0.3",
    "redis": "5.11.0",
    "sharp": "^0.33.4",
    "simplex-noise": "4.0.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "4.8.3",
    "swagger-ui-express": "5.0.1",
    "three": "0.183.2",
    "three-custom-shader-material": "6.4.0",
    "vite-plugin-glsl": "1.5.6",
    "web-push": "3.6.7",
    "yaml": "2.8.3",
    "zustand": "5.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "//overrides_note": "Force a single React + zustand across the whole tree. leva ships zustand@3, tunnel-rat (via @react-three) ships zustand@4, top-level uses 5 — three zustands meant three React references and Vite ended up wiring component code to one and zustand to another, throwing 'Cannot read properties of null (reading useCallback)' the first time any store rendered.",
  "overrides": {
    "zustand": "5.0.12",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/node": "25.6.0",
    "@vitejs/plugin-react": "5.0.4",
    "@vitest/coverage-v8": "4.1.4",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "openapi-typescript": "7.13.0",
    "pg": "8.20.0",
    "pino-pretty": "13.1.3",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.2",
    "vite": "7.1.9",
    "vitest": "4.1.2"
  }
}
