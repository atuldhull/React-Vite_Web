{
  "name": "math-club-website",
  "version": "2.0.0",
  "description": "Math Collective — A competitive mathematics platform for university students",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:server": "nodemon server.js",
    "dev:frontend": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "build:frontend": "vite build --config vite.config.js",
    "preview:frontend": "vite preview --config vite.config.js",
    "lint": "eslint frontend/src/ --ext .js,.jsx --quiet",
    "lint:fix": "eslint frontend/src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"frontend/src/**/*.{js,jsx,css}\" \"controllers/**/*.js\" \"routes/**/*.js\"",
    "format:check": "prettier --check \"frontend/src/**/*.{js,jsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "math",
    "competitive",
    "university"
  ],
  "author": "Math Collective, BMSIT",
  "license": "MIT",
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/space-grotesk": "5.2.10",
    "@gsap/react": "2.1.2",
    "@react-spring/three": "10.0.3",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.5.0",
    "@react-three/postprocessing": "3.0.4",
    "@react-three/rapier": "2.2.0",
    "@supabase/supabase-js": "2.99.1",
    "alea": "1.0.1",
    "archiver": "7.0.1",
    "axios": "1.13.6",
    "bcryptjs": "3.0.3",
    "body-parser": "2.2.2",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "express-session": "1.19.0",
    "framer-motion": "12.38.0",
    "gsap": "3.14.2",
    "helmet": "8.1.0",
    "howler": "2.2.4",
    "html5-qrcode": "2.3.8",
    "jsonwebtoken": "9.0.3",
    "lenis": "1.3.21",
    "leva": "0.10.1",
    "mathjs": "15.1.1",
    "mongoose": "9.2.4",
    "multer": "^1.4.5-lts.1",
    "nerdamer": "1.1.13",
    "node-fetch": "3.3.2",
    "nodemailer": "^6.9.13",
    "nodemon": "3.1.14",
    "pdfkit": "^0.15.0",
    "postprocessing": "6.39.0",
    "qrcode.react": "4.2.0",
    "razorpay": "2.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "react-spring": "10.0.3",
    "sharp": "^0.33.4",
    "simplex-noise": "4.0.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "4.8.3",
    "three": "0.183.2",
    "three-custom-shader-material": "6.4.0",
    "vite-plugin-glsl": "1.5.6",
    "zustand": "5.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "tailwindcss": "3.4.17",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  }
}
