# ═══════════════════════════════════════════════════════════════
#  Math Collective — environment variable template
#  Copy this to .env.local and fill in real values.
#  See README -> "Environment Variables" for what each does.
#
#  EXPOSURE RULES — read before touching anything:
#    SERVER-ONLY   never reaches the browser; live as backend env
#                  vars only (Render → Environment, .env.local for
#                  dev). If a server-only value ever shows up in
#                  public/app/assets/* the build will refuse to ship
#                  (scripts/scan-bundle-secrets.mjs).
#    CLIENT-SAFE   Vite bakes these into the browser bundle, so they
#                  are public-by-design. MUST be prefixed `VITE_`.
#                  Never put a secret here.
# ═══════════════════════════════════════════════════════════════

# ───── REQUIRED — SERVER-ONLY (app won't boot without these in production) ─────

# Node environment. Set to "production" on deployed instances.
NODE_ENV=development

# Supabase project URL — Settings → API in the Supabase dashboard.
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Supabase service_role key (legacy JWT starting with eyJ…).
# NEVER expose this client-side. Bypasses RLS by design.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Random 32+ char string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace_me_with_a_long_random_string

# ───── PRODUCTION-ONLY — SERVER-ONLY ─────

# Public origin — used for CORS allow-list and cert verify URLs.
# Local dev is auto-allowed; set this to your prod hostname.
FRONTEND_URL=https://math-collective.onrender.com

# Postgres-backed express-session store — same DB as Supabase
# is fine. Transaction-pooler URI works. URL-encode special
# chars in the password (@ becomes %40, etc.).
# Dev falls back to MemoryStore if this is unset.
SESSION_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ───── FEATURE-GATED — SERVER-ONLY (feature silently disables if missing) ─────

# Enables PANDA / ΣBot tutor + AI question generator.
# Sign up at https://openrouter.ai — $1 free credit.
OPENROUTER_API_KEY=sk-or-v1-...

# Gmail app password — enables the contact form, event invoice
# emails, and any server-side outbound mail. Requires 2-Step
# Verification on the account. Generate at:
# https://myaccount.google.com/apppasswords
CONTACT_EMAIL=you@gmail.com
CONTACT_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Razorpay — enables subscription-plan payments. Use Test keys
# during development; KYC required for Live mode.
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Web-push (VAPID) — enables browser push notifications.
# Generate with: node backend/scripts/generateVapidKeys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:you@example.com

# Sentry (server-side) — enables backend error reporting. Free-tier
# DSN works. Project: backend/Node, find under Settings → Client Keys.
SENTRY_DSN=

# Gemini (Google) — primary LLM provider. Free tier covers
# PANDA / ΣBot tutor + the teacher question generator end-to-end;
# falls back to OPENROUTER_API_KEY when missing. Get a key at
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Sentry source-map upload — these three together enable
# @sentry/vite-plugin to upload source maps during `npm run build`
# and strip them from public/app so they aren't served to clients.
# All three must be set for upload to activate; otherwise the plugin
# silently no-ops (local dev / preview deploys without secrets work
# fine). Auth token: User Settings → Auth Tokens → "Create New" with
# the `project:releases` + `org:read` scopes.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ───── OPTIONAL — SERVER-ONLY ─────

# Override the port the backend listens on. Defaults to 3000.
PORT=3000

# Public URL used in outbound emails (cert verify links, invite links,
# password reset CTA). Falls back to FRONTEND_URL when unset.
PUBLIC_URL=

# Base URL used in org-invite links rendered into invitation emails.
# Defaults to FRONTEND_URL in practice; set explicitly if your invite
# domain differs from your app domain.
BASE_URL=

# pino logger level. "debug" in dev, "info" on prod by default.
# Override to "warn" or "error" to make Render logs quieter.
LOG_LEVEL=

# Redis URL — opt-in. Enables (a) Socket.IO pub/sub across multiple
# instances and (b) live-quiz state persistence across restarts.
# Single-instance deploys work fine without it.
REDIS_URL=

# Extra comma-separated banned words appended to the built-in list
# in backend/lib/contentFilter.js. Leave blank to use defaults only.
BANNED_WORDS_EXTRA=

# ───── CLIENT-SAFE (browser-exposed via Vite — must be VITE_* prefixed) ─────

# VAPID public key for web-push subscriptions. Must match the
# VAPID_PUBLIC_KEY above (the SAME key — server signs with the
# private half, the client subscribes with the public half).
# Generate both with: node backend/scripts/generateVapidKeys.js
VITE_VAPID_PUBLIC_KEY=

# Sentry (frontend, Vite) — enables React error reporting. Create a
# SEPARATE Sentry project of type "Browser/React" (so platform-specific
# scrubbing rules apply correctly). Falls back to no-op when unset.
# A DSN is a public identifier — safe to expose.
VITE_SENTRY_DSN=
